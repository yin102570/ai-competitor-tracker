# ============================================================
# 环境变量模板 - 复制为 .env 并填入真实值
# 安全规则：所有密钥必须通过环境变量注入，严禁硬编码
# ============================================================

# --- 应用配置 ---
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_NAME=ai-competitor-tracker

# --- 数据库 ---
DATABASE_URL=sqlite+aiosqlite:///./data/tracker.db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_TOKEN_BLACKLIST_DB=1

# --- JWT密钥（生产环境必须替换为随机256位密钥）---
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_256_BIT_KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- API Key ---
API_KEY_PREFIX=act_
API_KEY_LENGTH=32

# --- DeepSeek API ---
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- 爬虫配置 ---
SPIDER_CONCURRENCY=5
SPIDER_RATE_LIMIT_PER_SEC=2
SPIDER_PROXY_POOL_URL=

# --- 日志 ---
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
